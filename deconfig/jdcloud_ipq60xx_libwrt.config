# 你原始 config + 只加必要内容版（2025.11.20）
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01="ipq-wifi-jdcloud_re-ss-01 zram-swap luci-app-cupsd"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="ipq-wifi-jdcloud_re-cs-02 ath11k-firmware-qcn9074 luci-app-athena-led luci-i18n-athena-led-zh-cn luci-app-cupsd"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07="luci-app-dockerman luci-i18n-dockerman-zh-cn luci-app-cupsd"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud="ipq-wifi-redmi_ax5-jdcloud zram-swap"

CONFIG_TARGET_ROOTFS_INITRAMFS=n

# ==================== 下面是新增的必要内容 ====================

# 1. 强制 1GB 内存识别 + 大 overlay
CONFIG_MEM_TOTAL_1024=y
CONFIG_GRAND_FLASH_SIZE_256=y
CONFIG_TARGET_ROOTFS_PARTSIZE=180

# 2. RE-SS-01 正确 WiFi 驱动（去掉错误的 pci，换成 ahb）
CONFIG_PACKAGE_kmod-ath11k-ahb=y
CONFIG_PACKAGE_ath11k-firmware-qcn9074=y
CONFIG_PACKAGE_ipq-wifi-jdcloud_re-ss-01=y

# 3. NSS 全硬件加速补全（原来只开了几个残缺的）
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-ecm-standard=y
CONFIG_PACKAGE_kmod-qca-nss-ecm-sfe=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y

# 4. 网络性能拉满
CONFIG_TCP_CONG_BBR3=y
CONFIG_DEFAULT_FQ_PIE=y

# 5. 预装 OpenClash（你说之前没装上）
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y

# ==================== 你原来的全部内容原样保留（从这里开始） ====================
CONFIG_USE_APK=n
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_BUSYBOX_CONFIG_TELNET=y
